# DCMMS系统环境配置
# 复制此文件为 .env 并修改配置

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# SQLite配置
SQLITE_DB_PATH=data/dcmm_system.db

# 系统配置
SYSTEM_NAME=DCMMS
SYSTEM_VERSION=1.0.0
LOG_LEVEL=INFO

# 性能配置
MAX_CONTEXT_TOKENS=8000
COMPRESSION_RATIO=0.7
DEFAULT_TTL=3600

# 监控配置
MONITORING_ENABLED=true
METRICS_RETENTION_DAYS=30
